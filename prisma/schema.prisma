// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * GENERIC TEMPLATE MODEL
 * This is a dummy model to demonstrate Prisma patterns.
 * Developers should copy and rename these for their own business models.
 */
model TemplateModel {
  id          String   @id @default(cuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  status      String   @default("DRAFT") // Example of using strings as simple enums
  
  // Timestamps are essential for every table
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("template_models") // Best practice: use snake_case for table names
}
