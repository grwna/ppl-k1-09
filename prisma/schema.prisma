generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  email            String            @unique
  password         String
  createdAt        DateTime          @default(now())
  donorFunds       DonorFund[]
  loanApplications LoanApplication[]
  notifications    Notification[]
  roles            UserRole[]
}

model Role {
  id    String     @id @default(uuid()) @db.Uuid
  name  String     @unique
  users UserRole[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model DonorFund {
  id           String        @id @default(uuid()) @db.Uuid
  donorId      String        @db.Uuid
  amount       Float
  remaining    Float
  createdAt    DateTime      @default(now())
  donor        User          @relation(fields: [donorId], references: [id], onDelete: Cascade)
  loanFundings LoanFunding[]
}

model LoanApplication {
  id                    String                @id @default(uuid()) @db.Uuid
  borrowerId            String                @db.Uuid
  requestedAmount       Float
  description           String
  collateralUrl         String
  collateralDescription String
  status                LoanApplicationStatus @default(PENDING)
  createdAt             DateTime              @default(now())
  loan                  Loan?
  borrower              User                  @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
}

model Loan {
  id             String          @id @default(uuid()) @db.Uuid
  applicationId  String          @unique @db.Uuid
  approvedAmount Float
  status         LoanStatus
  approvedAt     DateTime
  dueDate        DateTime
  application    LoanApplication @relation(fields: [applicationId], references: [id])
  fundings       LoanFunding[]
  repayments     Repayment[]
}

model LoanFunding {
  id          String            @id @default(uuid()) @db.Uuid
  loanId      String            @db.Uuid
  sourceType  FundingSourceType
  donorFundId String?           @db.Uuid
  amount      Float
  donorFund   DonorFund?        @relation(fields: [donorFundId], references: [id])
  loan        Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model Repayment {
  id     String          @id @default(uuid()) @db.Uuid
  loanId String          @db.Uuid
  amount Float
  paidAt DateTime
  status RepaymentStatus
  loan   Loan            @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  type        String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum LoanApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanStatus {
  ACTIVE
  PAID
  FORGIVEN
  DEFAULTED
}

enum FundingSourceType {
  DONOR
  INVESTOR
}

enum RepaymentStatus {
  PENDING
  CONFIRMED
}
